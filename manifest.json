{
  "manifest_version": 3,
  "name": "Pause & Breathe",
  "version": "1.0",
  "description": "Take a mindful pause before visiting distracting websites.",
  "permissions": ["storage", "webNavigation"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}
